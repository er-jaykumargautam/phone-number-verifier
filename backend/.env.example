PORT=3000
NODE_ENV=development

# Required. Atlas SRV form: mongodb+srv://user:pass@cluster.example.mongodb.net/dbname
MONGO_URI=

# Required (≥ 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

JWT_TTL_SECONDS=3600
OTP_TTL_SECONDS=300
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# "console" prints OTP to backend stdout. "twilio" sends real SMS.
SMS_TRANSPORT=console

# Required ONLY when SMS_TRANSPORT=twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
