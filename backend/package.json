{
  "name": "phone-number-verifier-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phone number verifier API server",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "offline": "serverless offline start --stage dev",
    "deploy": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "remove": "serverless remove --stage dev"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "serverless-http": "^3.2.0",
    "twilio": "^5.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "serverless": "^3.39.0",
    "serverless-offline": "^13.6.0"
  }
}
